# ============================================================================
# SchoolTrack — Variables d'environnement PRODUCTION
# Copier ce fichier en .env.prod et remplir les valeurs
# NE JAMAIS committer .env.prod dans le repo
# ============================================================================

# --- PostgreSQL ---
POSTGRES_DB=schooltrack
POSTGRES_USER=schooltrack
POSTGRES_PASSWORD=               # Mot de passe fort (min. 20 caractères)

# --- API (FastAPI) ---
SECRET_KEY=                      # Clé JWT 256 bits : python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=                  # Clé AES 256 bits : python -c "import secrets; print(secrets.token_hex(32))"

# --- SMTP (emails 2FA + reset mot de passe) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@schooltrack.yourschool.be
SMTP_USE_TLS=true

# --- Domaines (DNS A → 81.88.25.75) ---
API_DOMAIN=api.schooltrack.yourschool.be
DASHBOARD_DOMAIN=dashboard.schooltrack.yourschool.be
PGADMIN_DOMAIN=pgadmin.schooltrack.yourschool.be
PORTAINER_DOMAIN=portainer.schooltrack.yourschool.be

# --- Let's Encrypt ---
ACME_EMAIL=admin@schooltrack.be

# --- pgAdmin ---
PGADMIN_EMAIL=admin@schooltrack.be
PGADMIN_PASSWORD=                # Mot de passe fort

# --- Grafana ---
GRAFANA_DOMAIN=grafana.schooltrack.yourschool.be
GRAFANA_USER=admin
GRAFANA_PASSWORD=                # Mot de passe fort
