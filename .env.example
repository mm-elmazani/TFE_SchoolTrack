# ============================================================
# SchoolTrack — Variables d'environnement (DEV)
# Copier ce fichier en .env (cp .env.example .env)
# NE JAMAIS committer le fichier .env
# Les valeurs par defaut suffisent pour lancer localement avec
# `docker compose up -d`. Voir docs/DEPLOY-PRODUCTION.md pour la prod.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=schooltrack
POSTGRES_USER=schooltrack
POSTGRES_PASSWORD=admin

# ---------- pgAdmin (interface web BDD, http://localhost:5050) ----------
PGADMIN_EMAIL=admin@schooltrack.be
PGADMIN_PASSWORD=admin

# ---------- FastAPI ----------
# Dans docker-compose, l'API utilise le service "postgres". Cette URL ne sert
# que si on lance le backend en dehors de Docker (pytest, uvicorn local).
DATABASE_URL=postgresql://schooltrack:admin@localhost:5432/schooltrack
SECRET_KEY=change-me-in-production-use-a-long-random-string
ENCRYPTION_KEY=dev-only-change-in-production-32chars!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENV=development

# ---------- Domaine API (sert uniquement aux labels Traefik) ----------
# Laisser "localhost" en dev (l'API repond sur http://localhost:8000 directement)
API_DOMAIN=localhost
ACME_EMAIL=admin@schooltrack.be

# ---------- SMTP (optionnel en dev - sert au 2FA email + reset password) ----------
# Sans SMTP configure, le code de reinitialisation s'affiche dans les logs API.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@schooltrack.be
SMTP_USE_TLS=true
